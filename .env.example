# GEMINI_API_KEY: required by the Cloud Run server to evaluate boss responses.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# PORT: optional for local runs. Cloud Run injects this automatically.
PORT="8080"

# GEMINI_MODEL: optional override for model selection.
GEMINI_MODEL="gemini-3-flash-preview"

# VITE_API_PROXY_TARGET: optional local dev proxy target for /api requests.
VITE_API_PROXY_TARGET="http://localhost:8080"
